# =============================================================================
# Lab Monitor — example environment file.
# Copy to `.env` and fill in real values. `.env` is git-ignored; never commit it.
# The Go server reads ALL configuration from environment variables (12-factor):
# there are no secrets in code.
# =============================================================================

# --- Database -----------------------------------------------------------------
# Inside docker-compose the host is the service name `timescaledb`.
# For local `go run` against the dev compose DB, use localhost:5432.
POSTGRES_USER=labmon
POSTGRES_PASSWORD=labmon-dev-password-change-me
POSTGRES_DB=labmon
DATABASE_URL=postgres://labmon:labmon-dev-password-change-me@timescaledb:5432/labmon?sslmode=disable

# --- HTTP server --------------------------------------------------------------
HTTP_ADDR=:8080

# --- Ingest auth (machine tokens) ---------------------------------------------
# Comma-separated `source:token` pairs. Each token may ONLY write its own source,
# so a leaked lab token cannot forge another instrument's data. Revoke by removing
# the pair and restarting the server.
INGEST_TOKENS=unisoku-stm:dev-ingest-token-change-me

# --- Admin login (control plane, JWT) -----------------------------------------
# Credentials live only in env, never in code or the database.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dev-admin-password-change-me
# HS256 signing secret for issued JWTs. Generate: `openssl rand -hex 32`
JWT_SECRET=please-generate-a-long-random-secret-change-me
JWT_TTL_HOURS=24

# --- Alerting (all optional; unset channels are simply skipped) ---------------
# A threshold cross is always recorded in alert_log and logged to stdout even if
# no notifier is configured, so alerting is observable without SMTP/Slack.
ALERT_DEBOUNCE_SECONDS=300
# Hard cap on alert emails dispatched per UTC day (0 = unlimited). Protects the
# email free tier / inbox; crosses past the cap are still recorded in alert_log.
ALERT_MAX_EMAILS_PER_DAY=50

# SMTP email (leave SMTP_HOST blank to disable email). Example: Amazon SES SMTP.
SMTP_HOST=            # e.g. email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=        # SES SMTP username (from "Create SMTP credentials")
SMTP_PASSWORD=        # SES SMTP password
SMTP_FROM=            # a verified SES identity, e.g. you@example.com
ALERT_EMAIL_TO=       # recipient(s), comma-separated

# Slack incoming webhook (leave blank to disable)
SLACK_WEBHOOK_URL=

# --- InfluxDB -> AWS forwarder (deploy/docker-compose.yml `forwarder`) ---------
# Read-only mirror of the lab's InfluxDB Cloud data into AWS. The InfluxDB
# credentials are the lab's (an all-access or read-capable token).
INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_TOKEN=
INFLUX_ORG=
INFLUX_TEMP_BUCKET=Temperature_Logger
INFLUX_PRESSURE_BUCKET=Pressure_Logger
FORWARDER_POLL_SECONDS=15
