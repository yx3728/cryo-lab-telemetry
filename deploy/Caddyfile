# Production reverse proxy with automatic HTTPS.
#
# sslip.io resolves 3.220.132.187.sslip.io -> 3.220.132.187, so Caddy can obtain
# a real Let's Encrypt certificate over the open ports 80/443. API paths go to
# the Go service; everything else is the static React build (SPA fallback).

3.220.132.187.sslip.io {
	encode gzip

	# Backend: ingest + read/control API + ops endpoints.
	@api path /api/* /ingest /healthz /metrics
	handle @api {
		reverse_proxy go-api:8080
	}

	# Frontend: static single-page app, with history-API fallback to index.html.
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
